# Instagram credentials — use a SECONDARY account, never your main one
INSTAGRAM_USERNAME=your_secondary_account
INSTAGRAM_PASSWORD=your_password

# Your Railway backend
RAILWAY_API_URL=https://penta-crm-production.up.railway.app

# Must match SCRAPER_API_KEY set in Railway environment variables
SCRAPER_API_KEY=choose_a_long_random_secret_here

# Scraping behaviour
SCRAPER_MAX_RESULTS=50
SCRAPER_MIN_DELAY=5
SCRAPER_MAX_DELAY=15
SCRAPER_BREAK_EVERY=20
SCRAPER_BREAK_SECONDS=120
